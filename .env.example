# Solana RPC URL (mainnet). Use a dedicated RPC (Helius, QuickNode, etc.) for higher rate limits and better performance.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Redis connection URL
REDIS_URL=redis://localhost:6379

# PostgreSQL connection string (automatically provided by Replit)
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Server port (automatically provided by Replit)
PORT=8080

# CORS allowed origin (comma-separated for multiple). Omit to allow all origins.
# CORS_ORIGIN=http://localhost:5173,https://your-app.example.com
